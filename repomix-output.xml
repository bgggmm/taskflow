              x: particle.left + '%',
              y: particle.top + '%',
              scale: particle.scale,
            }}
            animate={{
              y: [null, particle.yEnd + '%'],
              opacity: [0.3, 0.6, 0.3],
            }}
            transition={{
              duration: particle.duration,
              repeat: Infinity,
              ease: "easeInOut",
            }}
            style={{
